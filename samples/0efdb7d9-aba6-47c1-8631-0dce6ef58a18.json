{
  "system": {
    "project_name": "drawio_kato",
    "repository": "https://github.com/thippi555/drawio_kato",
    "aws_region": "ap-northeast-1",
    "runtime": "python3.12",
    "iac": "Terraform",
    "implementation_type": "RAG with Bedrock",
    "api_route": "POST /tasks",
    "lambda_function": "drawio-kato-task-processor",
    "state_machine": "drawio-kato-task-flow",
    "bedrock_model_id": "global.anthropic.claude-haiku-4-5-20251001-v1:0"
  },
  "services": {
    "api_gateway": {
      "route": "POST /tasks",
      "description": "RAGクエリ受付エンドポイント"
    },
    "lambda": {
      "function_name": "drawio-kato-task-processor",
      "memory_mb": 512,
      "timeout_seconds": 60,
      "handler": "handler.lambda_handler",
      "description": "RAGリクエスト処理・Step Functions起動"
    },
    "step_functions": {
      "state_machine_name": "drawio-kato-task-flow",
      "description": "RAGワークフロー制御"
    },
    "bedrock": {
      "model_id": "global.anthropic.claude-haiku-4-5-20251001-v1:0",
      "description": "RAG応答生成"
    },
    "s3": {
      "bucket_name": "drawio-kato-artifacts",
      "description": "ドキュメント・結果保存"
    },
    "dynamodb": {
      "table_name": "ai_agent_tasks",
      "description": "タスク・メタデータ管理"
    }
  },
  "workflow": [
    {
      "from": "API Gateway",
      "to": "Lambda",
      "label": "POST /tasks (query, document_type)"
    },
    {
      "from": "Lambda",
      "to": "Step Functions",
      "label": "StartExecution (task_id, query)"
    },
    {
      "from": "Step Functions",
      "to": "S3",
      "label": "SearchDocuments (tasks/ prefix)"
    },
    {
      "from": "Step Functions",
      "to": "S3",
      "label": "LoadPromptTemplate (prompts/)"
    },
    {
      "from": "Step Functions",
      "to": "Bedrock",
      "label": "InvokeModel (context + query)"
    },
    {
      "from": "Bedrock",
      "to": "Step Functions",
      "label": "Return generated response"
    },
    {
      "from": "Step Functions",
      "to": "S3",
      "label": "SaveResults (outputs/)"
    },
    {
      "from": "Step Functions",
      "to": "DynamoDB",
      "label": "UpdateTaskStatus"
    },
    {
      "from": "Lambda",
      "to": "API Gateway",
      "label": "Return task_id, status"
    }
  ],
  "storage": {
    "s3_prefixes": {
      "tasks": "入力ドキュメント・クエリ",
      "outputs": "生成結果（design.md, artifact.json）",
      "prompts": "RAGプロンプトテンプレート",
      "logs": "処理ログ"
    },
    "output_files": [
      "design.md",
      "architecture.drawio",
      "artifact.json"
    ],
    "artifact_bucket": "drawio-kato-artifacts",
    "output_prefix": "outputs/0efdb7d9-aba6-47c1-8631-0dce6ef58a18/",
    "task_prefix": "tasks/0efdb7d9-aba6-47c1-8631-0dce6ef58a18/"
  },
  "dynamodb": {
    "table_name": "ai_agent_tasks",
    "partition_key": {
      "name": "task_id",
      "type": "String"
    },
    "attributes": [
      {
        "name": "query",
        "type": "String",
        "description": "ユーザークエリ"
      },
      {
        "name": "status",
        "type": "String",
        "description": "processing/completed/failed"
      },
      {
        "name": "created_at",
        "type": "String",
        "description": "ISO8601タイムスタンプ"
      },
      {
        "name": "result_s3_path",
        "type": "String",
        "description": "結果ファイルS3パス"
      },
      {
        "name": "document_count",
        "type": "Number",
        "description": "検索ドキュメント数"
      },
      {
        "name": "model_id",
        "type": "String",
        "description": "使用Bedrockモデル"
      }
    ],
    "billing_mode": "PAY_PER_REQUEST"
  },
  "files": {
    "terraform": [
      "main.tf",
      "lambda.tf",
      "stepfunctions.tf",
      "s3.tf",
      "dynamodb.tf",
      "iam.tf",
      "variables.tf",
      "outputs.tf"
    ],
    "lambda": [
      "handler.py",
      "rag_processor.py",
      "bedrock_client.py",
      "s3_handler.py",
      "dynamodb_handler.py",
      "requirements.txt"
    ],
    "prompts": [
      "system.txt",
      "rag_template.txt"
    ],
    "stepfunctions": [
      "rag_workflow.json"
    ]
  },
  "future_extensions": [
    {
      "name": "Vector Database Integration",
      "description": "Amazon Titan Embeddings + OpenSearch Serverlessでセマンティック検索実装"
    },
    {
      "name": "Lambda Function Splitting",
      "description": "検索専用Lambda、生成専用Lambdaに分割"
    },
    {
      "name": "Caching Layer",
      "description": "ElastiCacheでクエリ結果キャッシング"
    },
    {
      "name": "Multi-Model Support",
      "description": "Claude 3 Sonnet等複数モデル対応"
    }
  ],
  "schema_version": "2026-05-15.1"
}